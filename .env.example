# Groq — https://console.groq.com (free, no CC needed)
GROQ_API_KEY=your_groq_api_key_here

# Cohere — https://dashboard.cohere.com (free trial)
COHERE_API_KEY=your_cohere_api_key_here

# LangSmith — https://smith.langchain.com (free tier)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=algo-rag

# Project Config
CHROMA_DB_PATH=./data/chroma_db
CPP_REPO_PATH=./data/raw/C-Plus-Plus
LOG_LEVEL=INFO

# Disable ChromaDB telemetry (fixes posthog signature error with chromadb==1.0.12)
ANONYMIZED_TELEMETRY=False
